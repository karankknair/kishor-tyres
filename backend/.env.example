# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — leave blank for SQLite (development), set for PostgreSQL (production)
DATABASE_URL=
# OR use individual vars (deprecated, prefer DATABASE_URL):
# DB_NAME=kishor_tyres
# DB_USER=postgres
# DB_PASSWORD=password

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Twilio (WhatsApp/SMS notifications)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Frontend URL (for CORS allow-list)
FRONTEND_URL=http://localhost:3000
